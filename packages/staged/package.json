{
  "name": "staged",
  "version": "0.1.0",
  "description": "Staged AI coding daemon — run AI coding agents on your local machine",
  "bin": {
    "staged": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --platform node --target node18 --out-dir dist --no-splitting",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ai": "^6.0.141",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/xai": "^3.0.75",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
